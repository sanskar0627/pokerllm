# ─── LLM API Keys ────────────────────────────────────────────────────────────
# At least one is required for AI players to work.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=

# ─── Database (Neon Postgres via Prisma) ─────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ─── Authentication (NextAuth) ───────────────────────────────────────────────
AUTH_SECRET=           # Generate with: openssl rand -base64 32
AUTH_GOOGLE_ID=        # Google OAuth client ID (optional, for Google login)
AUTH_GOOGLE_SECRET=    # Google OAuth client secret

# ─── Email (for verification emails) ─────────────────────────────────────────
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=

# ─── Redis (game state persistence) ──────────────────────────────────────────
# Include password in the URL. Default dev password is pokerllm_dev_redis_2024.
# In production, set REDIS_PASSWORD env var and use a strong password.
REDIS_PASSWORD=pokerllm_dev_redis_2024
REDIS_URL=redis://:pokerllm_dev_redis_2024@localhost:6379

# ─── Production Settings ─────────────────────────────────────────────────────
# REQUIRED in production — comma-separated allowed origins for Socket.io CORS.
# Example: https://pokerllm.com,https://www.pokerllm.com
# Server will refuse to start in production if this is not set.
ALLOWED_ORIGIN=

# Secret for protecting the cron cleanup endpoint (required in all environments).
CRON_SECRET=
